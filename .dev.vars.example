# Secret 1: REQUIRED. The user must provide this.
ADMIN_EMAIL=

# Secret 2: OPTIONAL — auto-generated by the Worker on first request.
# The deploy form will still mark this as required and block deploy if blank.
MCP_BEARER_TOKEN=

# Secret 3: OPTIONAL — only needed if the user wants webhook notifications.
# The deploy form will still block deploy if blank.
OPTIONAL_WEBHOOK_URL=
